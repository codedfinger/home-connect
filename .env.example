# Copy to .env at the repository root (optional — defaults work for local SQLite).

# Seed admin (pnpm --filter @workspace/db run seed). Change password in production.
# SEED_ADMIN_EMAIL=admin@homeconnect.local
# SEED_ADMIN_PASSWORD=admin123

# SQLite database file. Relative paths are resolved from the monorepo root
# (directory that contains pnpm-workspace.yaml). Default: data/homeconnect.db
# SQLITE_PATH=data/homeconnect.db

# API port (optional; defaults to 8080)
PORT=8080

# Frontend dev server (optional; defaults to 5173)
# PORT=5173

# Proxy target for Vite (optional; defaults to http://127.0.0.1:8080)
# VITE_API_PROXY=http://127.0.0.1:8080
